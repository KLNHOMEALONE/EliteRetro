<?xml version="1.0" encoding="utf-8"?>
<XNAFramework xmlns="http://microsoft.com/xna/2006/10/Microsoft.Xna.Framework.Content.Pipeline.Font.Description">
  <FontName>Microsoft Sans Serif</FontName>
  <Size>16</Size>
  <Spacing>0</Spacing>
  <UseKerning>true</UseKerning>
  <Style>Regular</Style>
  <CharacterRegions>
    <CharacterRegion>
      <Start>&#32;</Start>
      <End>&#126;</End>
    </CharacterRegion>
  </CharacterRegions>
</XNAFramework>
